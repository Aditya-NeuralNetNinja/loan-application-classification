# ============================================================
# HMDA Big Data ML Project — .gitignore
# ============================================================

# --- Data files (too large for Git) ---
data/raw/
data/processed/*
data/samples/*.csv
*.csv
*.parquet
*.pkl

# --- Deployment sample assets (tracked) ---
!app/assets/*.csv
!app/assets/*.json

# --- Deployable inference artifacts (tracked) ---
!data/processed/feature_metadata.json
!data/processed/optimal_threshold.json
!data/processed/pipeline_model/
!data/processed/pipeline_model/**
!data/processed/models/
!data/processed/models/best_gbt/
!data/processed/models/best_gbt/**
!data/processed/pipeline_model/**/*.parquet
!data/processed/models/best_gbt/**/*.parquet

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# --- Virtual environment ---
hmda_venv/
venv/
.env

# --- Jupyter ---
#.ipynb_checkpoints/
#*.ipynb_metadata/

# --- Spark ---
spark-warehouse/
metastore_db/
derby.log

# --- Models (large serialized files) ---
models/

# --- OS ---
.DS_Store
._*
*.crc
Thumbs.db


# --- Tableau (large binary files) ---
tableau/*.twbx
tableau/*.hyper
